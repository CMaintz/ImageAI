{
  "compilerOptions": {
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "target": "es2020",
    "lib": [
      "dom",
      "es2020"
    ],
    "allowJs": true,
    "paths": {
      "src/*": ["../../../../../../../vendor/shopware/storefront/Resources/app/storefront/src/*"]
    },
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "src/**/*"
  ]
}
